{
  // Use the uv-managed venv so Pylance resolves the MicroPython stubs
  // (machine, network, neopixel, ...) even though those modules only exist on the board.
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": true,

  // Let Pylance find the vendored device libs (st7789py, vga2_bold_16x16) that live in src/.
  "python.analysis.extraPaths": ["src"],
  "python.analysis.typeCheckingMode": "basic",
  "python-envs.defaultEnvManager": "ms-python.python:system"
}
